{% extends "base.jinja" %}

{% block title %}Your groups{% endblock %}

{% block content %}
<h1 class="title is-3">Your groups</h1>
{% if groups.is_empty() %}
    <p class="subtitle is-5">You don't have any groups yet.</p>
{% else %}
    <p class="subtitle is-5">Select a group to continue.</p>
{% endif %}

<div class="columns">
    <div class="column is-three-quarters">
        <div class="fixed-grid has-4-cols">
            <div class="grid" id="group-grid">
                {% for group in groups %}
                    {% include "partials/group_card.jinja" %}
                {% endfor %}
            </div>
        </div>
    </div>

    <div class="column is-one-quarter">
        <div class="card">
            <header class="card-header">
                <p class="card-header-title">Create a group</p>
            </header>

            <div class="card-content">
                <form id="create-group-form" hx-post="/groups" hx-target="#group-grid" hx-swap="beforeend">
                    <div class="field">
                        <label class="label" for="name">Name</label>
                        <div class="control">
                            <input class="input" type="text" id="name" name="name" placeholder="My Group">
                        </div>
                    </div>

                    <div class="field">
                        <label class="label" for="description">Description</label>
                        <div class="control">
                            <input class="input" type="text" id="description" name="description" placeholder="What's the group about?">
                        </div>
                    </div>
                </form>
            </div>

            <footer class="card-footer">
                <button class="card-footer-item button is-primary" form="create-group-form">
                    Create
                </button>
            </footer>
        </div>
    </div>
</div>

{% endblock %}
